BH_ADMIN_LISTEN=127.0.0.1:8730
BH_ADMIN_CLI=/usr/bin/gsrn_cli
BH_ADMIN_CLI_HOST=127.0.0.1
BH_ADMIN_CLI_PORT=48001
BH_ADMIN_BH_NETCAT=/usr/local/bin/bh-netcat
BH_ADMIN_DATA_DIR=/var/lib/bhsocket-admin

# Required. Use a long random password and expose the panel only over VPN or
# behind an HTTPS reverse proxy with IP allowlisting.
BH_ADMIN_USER=admin
BH_ADMIN_PASSWORD=change-this-long-random-password
