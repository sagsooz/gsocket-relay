# Optional systemd environment file for BH Socket relay deployments.
#
# Copy to /etc/bhsocket-relay.env and reference it from gsrnd.service if you
# want these values loaded by systemd.

# Limit relay egress shaping, for example: 100Mbit
# GS_LIMIT=

# Optional Telegram notifications used by gsrnd_start.sh.
# TG_TOKEN=
# TG_CHATID=

# Human-readable node name in notifications.
MYNAME=bh1
