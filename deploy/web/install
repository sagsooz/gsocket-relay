#!/usr/bin/env bash
set -euo pipefail

BH_HOST="${BH_HOST:-bhsocket.io}"
BH_PORT="${BH_PORT:-443}"
BH_BASE_URL="${BH_BASE_URL:-https://bhsocket.io}"
BH_NAME="bh-netcat"
BH_TMP=""

say() { printf '%s\n' "$*"; }
step() { printf '%-70s' "--> $*"; }
ok() { printf '[OK]\n'; }
failed() { printf '[FAILED]\n'; }
fail() { printf 'bh-netcat install failed: %s\n' "$*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"; }

pick_prefix() {
  if [[ -n "${BH_PREFIX:-}" ]]; then
    printf '%s\n' "$BH_PREFIX"
    return
  fi

  local dir home_dir
  IFS=':' read -r -a path_dirs <<<"${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    case "$dir" in
      /opt/homebrew/bin|/usr/local/bin|/usr/bin)
        if [[ -d "$dir" && -w "$dir" && -x "$dir" ]]; then
          printf '%s\n' "${dir%/bin}"
          return
        fi
        ;;
    esac
  done

  if [[ "$(id -u)" = "0" ]]; then
    printf '/usr/local\n'
    return
  fi

  home_dir="${HOME:-}"
  if [[ -z "$home_dir" ]]; then
    home_dir="$(getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6 || true)"
  fi
  if [[ -z "$home_dir" ]]; then
    home_dir="$(cd ~ 2>/dev/null && pwd || true)"
  fi
  [[ -n "$home_dir" ]] || fail "HOME is not set; set BH_PREFIX= to an install directory"
  printf '%s\n' "${home_dir}/.local"
}

detect_package() {
  local os arch
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m | tr '[:upper:]' '[:lower:]')"

  case "$os:$arch" in
    linux:x86_64|linux:amd64) printf 'bh-netcat_x86_64-linux.tar.gz\n' ;;
    linux:aarch64|linux:arm64) printf 'bh-netcat_aarch64-linux.tar.gz\n' ;;
    linux:armv6l|linux:armv7l|linux:arm) printf 'bh-netcat_arm-linux.tar.gz\n' ;;
    darwin:x86_64) printf 'bh-netcat_x86_64-osx.tar.gz\n' ;;
    darwin:aarch64|darwin:arm64) printf 'bh-netcat_aarch64-osx.tar.gz\n' ;;
    mingw*:x86_64|msys*:x86_64|cygwin*:x86_64) printf 'bh-netcat_x86_64-cygwin.tar.gz\n' ;;
    *) fail "unsupported platform: ${os}/${arch}" ;;
  esac
}

package_label() {
  case "$1" in
    bh-netcat_x86_64-linux.tar.gz) printf 'x86_64-linux\n' ;;
    bh-netcat_aarch64-linux.tar.gz) printf 'aarch64-linux\n' ;;
    bh-netcat_arm-linux.tar.gz) printf 'arm-linux\n' ;;
    bh-netcat_x86_64-osx.tar.gz) printf 'x86_64-osx\n' ;;
    bh-netcat_aarch64-osx.tar.gz) printf 'aarch64-osx\n' ;;
    bh-netcat_x86_64-cygwin.tar.gz) printf 'x86_64-cygwin\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

write_wrapper() {
  local bin_path="$1" real_path="$2"
  cat >"$bin_path" <<EOF_WRAPPER
#!/usr/bin/env bash
BH_SOCKET_HOST="\${BH_SOCKET_HOST:-${BH_HOST}}"
BH_SOCKET_PORT="\${BH_SOCKET_PORT:-${BH_PORT}}"
BH_REAL="\${BH_REAL:-${real_path}}"

if [[ ! -x "\$BH_REAL" ]]; then
  printf 'bh-netcat: real executable not found: %s\\n' "\$BH_REAL" >&2
  exit 127
fi

export GSOCKET_HOST="\$BH_SOCKET_HOST"
export GSOCKET_PORT="\$BH_SOCKET_PORT"
export GS_HOST="\$BH_SOCKET_HOST"
export GS_PORT="\$BH_SOCKET_PORT"

for arg in "\$@"; do
  case "\$arg" in
    -h|--help|-m)
      "\$BH_REAL" "\$@" 2>&1 | sed 's/gs-netcat/bh-netcat/g'
      exit \${PIPESTATUS[0]:-0}
      ;;
  esac
done

if [[ -n "\${BASH_VERSION:-}" ]]; then
  exec -a bh-netcat "\$BH_REAL" "\$@"
fi

exec "\$BH_REAL" "\$@"
EOF_WRAPPER
  chmod 0755 "$bin_path"
}

download() {
  local url="$1" out="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$out"
    return
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -qO "$out" "$url"
    return
  fi
  fail "missing required command: curl or wget"
}

cleanup() {
  if [[ -n "$BH_TMP" ]]; then
    rm -rf "$BH_TMP"
  fi
}

remove_install() {
  local prefix="$1"
  rm -f "${prefix}/bin/${BH_NAME}"
  rm -f "${prefix}/lib/bhsocket/${BH_NAME}.real"
  if [[ -L "/usr/bin/${BH_NAME}" ]]; then
    rm -f "/usr/bin/${BH_NAME}"
  fi
  say "Removed ${prefix}/bin/${BH_NAME}"
}

install_client() {
  local prefix="$1" package tmp archive extracted bin_path lib_path real_path
  package="$(detect_package)"
  say "--> Installing ${BH_NAME} for $(package_label "$package")"

  tmp="$(mktemp -d)"
  BH_TMP="$tmp"
  trap cleanup EXIT
  archive="${tmp}/${package}"

  step "Downloading binary"
  if download "${BH_BASE_URL%/}/bin/${package}" "$archive"; then ok; else failed; return 1; fi

  step "Unpacking binary"
  if tar -xzf "$archive" -C "$tmp"; then ok; else failed; return 1; fi

  extracted="$(find "$tmp" -type f -perm -111 ! -name "${package}" | head -n 1)"
  [[ -n "$extracted" ]] || fail "downloaded package did not contain an executable"

  bin_path="${prefix}/bin/${BH_NAME}"
  lib_path="${prefix}/lib/bhsocket"
  real_path="${lib_path}/${BH_NAME}.real"

  mkdir -p "${prefix}/bin" "$lib_path"
  step "Installing command"
  if install -m 0755 "$extracted" "$real_path" && write_wrapper "$bin_path" "$real_path"; then ok; else failed; return 1; fi

  step "Testing command"
  if "$bin_path" -h >/dev/null 2>&1; then ok; else failed; return 1; fi

  say "--> Installed ${bin_path}"
  say "--> Relay default: ${BH_HOST}:${BH_PORT}"
  if [[ "$(command -v "$BH_NAME" 2>/dev/null || true)" != "$bin_path" ]]; then
    say "--> Add ${prefix}/bin to PATH if ${BH_NAME} is not found in a new shell."
  fi
  say ""
  say "--> To uninstall use BH_UNINSTALL=1 bash -c \"\$(curl -fsSL ${BH_BASE_URL%/}/install)\""
  say "--> Test: ${BH_NAME} -h"
  say "--> Connect: ${BH_NAME} -s \"SECRET_FROM_DEPLOY\" -i"
}

main() {
  need uname
  need tar
  need find
  need install
  need mktemp
  need id

  local prefix
  prefix="$(pick_prefix)"

  if [[ "${BH_UNINSTALL:-0}" = "1" ]]; then
    remove_install "$prefix"
    return
  fi

  install_client "$prefix"
}

main "$@"
